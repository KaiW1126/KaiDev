---
/**
 * ホームページ（index.astro）
 *
 * 構成：
 * 1. Hero セクション：自己紹介
 * 2. 記事一覧セクション：最新記事を表示
 */
export const prerender = true;
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

// 記事を取得して新着順にソート
const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 最新5件を表示
const recentPosts = posts.slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<!-- Hero セクション -->
			<section class="hero">
				<div class="hero-content">
					<h1 class="hero-title">
						Hi, I'm <span class="accent">Kai</span>
					</h1>
					<ul class="hero-list">
						<li>B2 情報理工</li>
						<li>エンジニアインターン中</li>
						<li>おつよいエンジニアを目指して日々精進</li>
						<li>学んだことをこのブログで発信しています</li>
					</ul>
					<div class="hero-links">
						<a href="/blog" class="btn btn-primary">
							記事を読む →
						</a>
						<a href="/about" class="btn btn-secondary">
							About Me
						</a>
					</div>
				</div>
			</section>

			<!-- 記事一覧セクション -->
			<section class="posts-section">
				<div class="section-header">
					<h2>Latest Posts</h2>
					<a href="/blog" class="view-all">すべて見る →</a>
				</div>

				<div class="posts-grid">
					{
						recentPosts.map((post) => (
							<ArticleCard
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								href={`/blog/${post.id}/`}
								tags={post.data.tags}
							/>
						))
					}
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		box-sizing: border-box;
		overflow-x: hidden;
	}

	/* Hero Section */
	.hero {
		padding: 4rem 0;
		text-align: center;
	}

	.hero-title {
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
		line-height: 1.3;
	}

	.accent {
		color: var(--color-accent);
	}

	.hero-list {
		list-style: none;
		padding: 0;
		margin: 0 auto 2rem auto;
		display: inline-block;
		text-align: left;
	}

	.hero-list li {
		font-size: 1.1rem;
		color: var(--color-text-muted);
		line-height: 2;
		position: relative;
		padding-left: 1.5rem;
	}

	.hero-list li::before {
		content: "•";
		position: absolute;
		left: 0;
		color: var(--color-accent);
		font-weight: bold;
	}

	.hero-links {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.btn-primary {
		background: var(--color-accent);
		color: white;
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
		transform: translateY(-2px);
	}

	.btn-secondary {
		background: var(--color-bg-secondary);
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* Posts Section */
	.posts-section {
		padding: 2rem 0;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
	}

	.section-header h2 {
		margin: 0;
		font-size: 1.5rem;
	}

	.view-all {
		font-size: 0.9rem;
		color: var(--color-accent);
		text-decoration: none;
	}

	.view-all:hover {
		text-decoration: underline;
	}

	.posts-grid {
		display: grid;
		gap: 1.5rem;
	}

	/* Responsive */
	@media (min-width: 640px) {
		.hero-title {
			font-size: 3rem;
		}

		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		main {
			padding: 1rem;
		}

		.hero {
			padding: 2rem 0;
		}

		.hero-content {
			text-align: center;
		}

		.hero-title {
			font-size: 1.75rem;
		}

		.hero-list {
			display: block;
			text-align: center;
			padding: 0;
		}

		.hero-list li {
			font-size: 0.95rem;
			padding-left: 0;
			text-align: center;
		}

		.hero-list li::before {
			display: none;
		}

		.hero-links {
			flex-direction: column;
			align-items: center;
		}

		.btn {
			width: 100%;
			max-width: 200px;
			justify-content: center;
		}
	}
</style>
