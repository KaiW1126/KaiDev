---
/**
 * About Me ページ
 *
 * セクション構成:
 * 1. プロフィール（自己紹介）
 * 2. 技術スタック
 * 3. 経歴・活動
 * 4. このブログについて
 * 5. リンク
 */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<html lang="ja">
	<head>
		<BaseHead title={`About Me | ${SITE_TITLE}`} description="Kaiのプロフィールページです。" />
	</head>
	<body>
		<Header />

		<main>
			<section class="profile">
				<h1>About Me</h1>
				<p class="intro">
					こんにちは、<strong>Kai</strong> です。情報理工学部の3年生で、エンジニアインターンで実務に取り組みながら開発を学んでいます。
					インフラからフロントエンドまで特定の領域に偏らず幅広く触れる中で、実務を通して「技術そのもの以上に、ビジネスとして本当に必要なものを見極めることが大切だ」と実感しました。
					目指しているのは、幅広い技術理解をもとに本質的に必要な仕様を見極め、それを素早く形にできるエンジニアです。学んだことはこのブログに記事として継続的にアウトプットし、知識を整理しながら技術力を高めています。
				</p>
			</section>

			<section class="skills">
				<h2>Skills</h2>
				<div class="skill-grid">
					<div class="skill-category">
						<h3>Languages</h3>
						<ul>
							<li>TypeScript / JavaScript</li>
							<li>Ruby</li>
						</ul>
					</div>
					<div class="skill-category">
						<h3>Frontend</h3>
						<ul>
							<li>React/React Native</li>
							<li>Next.js</li>
							<li>Astro</li>
							<li>Tailwind CSS</li>
						</ul>
					</div>
					<div class="skill-category">
						<h3>Backend / Infra</h3>
						<ul>
							<li>Ruby on Rails</li>
							<li>Supabase</li>
							<li>AWS</li>
						</ul>
					</div>
					<div class="skill-category">
						<h3>Tools</h3>
						<ul>
							<li>Git / GitHub</li>
							<li>VS Code</li>
							<li>Docker</li>
							<li>Claude Code</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="experience">
				<h2>Experience</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="timeline-date">2024年4月 ~</span>
						<div class="timeline-content">
							<h3>上智大学 情報理工学部</h3>
							<p>プログラミング、アルゴリズム、群論、離散数学などを学んでいます。</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-date">2025年 ~</span>
						<div class="timeline-content">
							<h3>個人開発 / その他の活動</h3>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-date">2025年3月 ~</span>
						<div class="timeline-content">
							<h3>エンジニアインターン</h3>
							<p>toCのアプリのweb, ネイティブアプリ両方でフルスタックで開発中</p>
						</div>
					</div>
				</div>
			</section>

			<section class="about-blog">
				<h2>About This Blog</h2>
				<p>
					このブログでは、日々の学習で得た知見や開発の記録を発信しています。
					開発に関するトピックを扱っていますが、興味のあるテーマがあれば幅広く書いていく予定です。
				</p>
				<p>
					アウトプットを通じて自分の理解を深めることと、同じ課題に取り組む人の助けになることを目指しています。
				</p>
			</section>

			<section class="links">
				<h2>Links</h2>
				<div class="link-list">
					<a
						href="https://github.com/KaiW1126"
						target="_blank"
						rel="noopener noreferrer"
						class="link-card"
					>
						<span class="link-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"
								><path
									d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
								></path></svg
							>
						</span>
						<span>GitHub</span>
					</a>
					<a
						href="https://zenn.dev/kai_skrj"
						target="_blank"
						rel="noopener noreferrer"
						class="link-card"
					>
						<span class="link-icon">
							<svg viewBox="0 0 88.3 88.3" width="24" height="24" fill="currentColor"
								><path
									d="M2.4 83.3h17c.9 0 1.7-.5 2.2-1.2L68.4 5.2c.6-1-.1-2.2-1.3-2.2H51.6c-.7 0-1.4.4-1.8 1L2.1 81.5c-.4.7.1 1.8 1.3 1.8h-1z"
								></path><path
									d="M61.4 83.3H78c1.1 0 1.8-1.2 1.3-2.1L59.2 47c-.4-.7-1.5-.7-1.9 0L47.5 62.6c-.5.9-.5 2 0 2.9l12 17.1c.4.5 1.1.7 1.9.7z"
								></path></svg
							>
						</span>
						<span>Zenn</span>
					</a>
					<a
						href="https://x.com/C1bjm32GV110480"
						target="_blank"
						rel="noopener noreferrer"
						class="link-card"
					>
						<span class="link-icon">
							<svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"
								><path
									d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
								></path></svg
							>
						</span>
						<span>X (Twitter)</span>
					</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}

	/* Profile */
	.profile {
		padding: 2rem 0;
	}

	.profile h1 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.intro {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--color-text-muted);
	}

	/* Skills */
	.skill-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		margin-top: 1rem;
	}

	.skill-category h3 {
		font-size: 1rem;
		margin-bottom: 0.5rem;
		color: var(--color-accent);
	}

	.skill-category ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.skill-category li {
		font-size: 0.95rem;
		color: var(--color-text-muted);
		padding: 0.25rem 0;
		position: relative;
		padding-left: 1rem;
	}

	.skill-category li::before {
		content: '▸';
		position: absolute;
		left: 0;
		color: var(--color-accent);
	}

	/* Experience */
	.timeline {
		margin-top: 1rem;
	}

	.timeline-item {
		display: flex;
		gap: 1.5rem;
		padding-bottom: 1.5rem;
		border-left: 2px solid var(--color-border);
		padding-left: 1.5rem;
		margin-left: 0.5rem;
		position: relative;
	}

	.timeline-item::before {
		content: '';
		width: 10px;
		height: 10px;
		background: var(--color-accent);
		border-radius: 50%;
		position: absolute;
		left: -6px;
		top: 4px;
	}

	.timeline-date {
		flex-shrink: 0;
		font-size: 0.85rem;
		color: var(--color-text-muted);
		min-width: 70px;
	}

	.timeline-content h3 {
		font-size: 1rem;
		margin: 0 0 0.25rem 0;
	}

	.timeline-content p {
		font-size: 0.95rem;
		color: var(--color-text-muted);
		margin: 0;
		line-height: 1.6;
	}

	/* About Blog */
	.about-blog p {
		color: var(--color-text-muted);
		line-height: 1.8;
	}

	/* Links */
	.link-list {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 1rem;
	}

	.link-card {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.25rem;
		background: var(--color-bg-secondary);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: var(--color-text);
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.link-card:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
	}

	.link-icon {
		display: flex;
		align-items: center;
	}

	/* Sections */
	section {
		padding: 1.5rem 0;
	}

	section + section {
		border-top: 1px solid var(--color-border);
	}

	/* Responsive */
	@media (max-width: 640px) {
		main {
			padding: 1rem;
		}

		.profile h1 {
			font-size: 1.75rem;
		}

		.skill-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.timeline-item {
			flex-direction: column;
			gap: 0.25rem;
		}

		.link-list {
			flex-direction: column;
		}

		.link-card {
			width: 100%;
			box-sizing: border-box;
		}
	}
</style>
