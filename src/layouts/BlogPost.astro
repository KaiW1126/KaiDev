---
/**
 * BlogPost.astro - 記事詳細ページのレイアウト
 * 
 * 機能：
 * - タイトル、公開日、更新日
 * - タグ表示
 * - Zenn リンク（存在する場合）
 * - ヒーロー画像
 * - 記事本文
 */
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags = [], zennUrl } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<!-- ヒーロー画像 -->
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				
				<div class="prose">
					<!-- 記事ヘッダー -->
					<header class="article-header">
						<!-- 公開日 -->
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">
									（更新: <FormattedDate date={updatedDate} />）
								</span>
							)}
						</div>
						
						<!-- タイトル -->
						<h1>{title}</h1>
						
						<!-- タグ -->
						{tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						)}
						
						<!-- Zenn リンク -->
						{zennUrl && (
							<a href={zennUrl} target="_blank" rel="noopener noreferrer" class="zenn-link">
								<svg viewBox="0 0 88.3 88.3" width="16" height="16" aria-hidden="true">
									<path fill="currentColor" d="M2.4 83.3h17c.9 0 1.7-.5 2.2-1.2L68.4 5.2c.6-1-.1-2.2-1.3-2.2H51.6c-.7 0-1.4.4-1.8 1L2.1 81.5c-.4.7.1 1.8 1.3 1.8h-1z"/>
									<path fill="currentColor" d="M61.4 83.3H78c1.1 0 1.8-1.2 1.3-2.1L59.2 47c-.4-.7-1.5-.7-1.9 0L47.5 62.6c-.5.9-.5 2 0 2.9l12 17.1c.4.5 1.1.7 1.9.7z"/>
								</svg>
								Zenn で読む
							</a>
						)}
					</header>
					
					<hr />

					<!-- 記事本文 -->
					<div class="content">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0;
	}

	.hero-image {
		width: 100%;
		margin-bottom: 2rem;
	}

	.hero-image img {
		display: block;
		margin: 0 auto;
		border-radius: 12px;
		box-shadow: var(--box-shadow);
	}

	.prose {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em;
	}

	.article-header {
		text-align: center;
		margin-bottom: 2rem;
	}

	.date {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		margin-bottom: 0.75rem;
	}

	.updated {
		font-style: italic;
	}

	.article-header h1 {
		margin: 0 0 1rem 0;
		font-size: 2rem;
		line-height: 1.3;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
		margin-bottom: 1rem;
	}

	.tag {
		font-size: 0.8rem;
		padding: 0.25rem 0.75rem;
		background: var(--color-bg-secondary);
		color: var(--color-accent);
		border-radius: 20px;
		font-weight: 500;
	}

	.zenn-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		background: #3ea8ff;
		color: white;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		transition: background 0.2s ease, transform 0.2s ease;
	}

	.zenn-link:hover {
		background: #0f83fd;
		transform: translateY(-2px);
		color: white;
	}

	hr {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 2rem 0;
	}

	.content {
		line-height: 1.8;
	}

	/* レスポンシブ */
	@media (max-width: 720px) {
		.article-header h1 {
			font-size: 1.5rem;
		}
	}
</style>
